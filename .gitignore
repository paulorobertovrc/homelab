# Secrets — never commit (.env, .env.bak, .env.local, ...)
media/.env*
!media/.env.example

# gluetun bundles + auto-updates its own server lists; don't version them (6MB+ of churn)
media/*.json

# App configs/DBs live on the host (/docker/appdata), never in the repo
appdata/

# import-gate: local test venv, bytecode, and test-generated state/fixtures
media/import-gate/.venv/
media/import-gate/**/__pycache__/
media/import-gate/tests/fixtures/
media/import-gate/**/*.db
