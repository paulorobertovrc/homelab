# Copy to .env and fill in the WireGuard values. .env is gitignored (never commit secrets).

# ── Identity / timezone ──────────────────────────────────────────────
PUID=1000
PGID=1000
TZ=America/Cuiaba

# ── Storage layout (WSL: downloads on ext4, library on F:\Media) ──────
CONFIG_ROOT=/docker/appdata   # app configs/DBs -> ext4 (fast, safe for SQLite)
DOWNLOADS=/data/torrents      # active downloads -> ext4 virtual disk
LIBRARY=/mnt/f/Media          # final library -> F: (Plex on Windows reads this)

# ── Network ──────────────────────────────────────────────────────────
SERVARR_SUBNET=172.31.0.0/24
SET_IP_GLUETUN=172.31.0.2
SET_IP_RADARR=172.31.0.11
SET_IP_SONARR=172.31.0.12
SET_IP_BAZARR=172.31.0.13
SET_IP_HOMEPAGE=172.31.0.20
SET_IP_RECYCLARR=172.31.0.14
SET_IP_ADDARR=172.31.0.15
SET_IP_TS_NTFY=172.31.0.16
# (prowlarr + qbittorrent + flaresolverr ride inside gluetun's namespace — no own IP)

# ── VPN (gluetun) ────────────────────────────────────────────────────
VPN_SERVICE_PROVIDER=mullvad
VPN_TYPE=wireguard
SERVER_COUNTRIES=Brazil
HEALTH_VPN_DURATION_INITIAL=30s

# From your Mullvad WireGuard config (Account -> WireGuard configuration -> Generate):
#   PrivateKey -> WIREGUARD_PRIVATE_KEY
#   Address    -> WIREGUARD_ADDRESSES   (e.g. 10.x.x.x/32,fc00:...:/128)
WIREGUARD_PRIVATE_KEY=
WIREGUARD_ADDRESSES=

# Host LAN IP (for ntfy links); leave localhost if unsure
LAN_IP=localhost

# Official Tailscale auth key (tagged, non-expiring) for the tailscale-ntfy sidecar.
# Generate at https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=

# Homepage dashboard (host port 7575): Host headers it will accept (CSRF guard).
# List every host:port you open it by; keep localhost:3000 for the container's own healthcheck.
HOMEPAGE_ALLOWED_HOSTS=localhost:3000,localhost:7575
